# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ─── JWT ─────────────────────────────────────────────────────────────────────
# 生产环境必须设置为随机长字符串（建议 >= 32 位）
JWT_SECRET=change-me-in-production

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=admin_platform
POSTGRES_USER=admin_platform
POSTGRES_PASSWORD=admin_platform

# ─── RustFS ───────────────────────────────────────────────────────────────────
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
